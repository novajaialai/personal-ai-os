# Internal HTTP router — Tailscale serve handles TLS externally.
# Listens on :80 inside Docker; exposed to host as 127.0.0.1:8080.

:80 {
	@intake path /intake/*
	handle @intake {
		reverse_proxy intake:8080
	}

	# Nextcloud lives at /files. overwritewebroot=/files is set on the Nextcloud
	# side, so Caddy must strip the /files prefix before proxying — Nextcloud's
	# own internal paths (status.php, remote.php/dav, apps, core, dist) are all
	# root-relative inside the container.
	@nextcloud path /files /files/*
	handle @nextcloud {
		uri strip_prefix /files
		reverse_proxy nextcloud:80
	}

	# Legacy unprefixed aliases (back-compat with clients configured pre-fix)
	@nextcloud_legacy path /remote.php/* /status.php /ocs/* /apps/* /core/* /dist/*
	handle @nextcloud_legacy {
		reverse_proxy nextcloud:80
	}

	# Agent handles everything else including the chat UI at /
	handle {
		reverse_proxy agent:3000
	}
}
