# Reverse proxy — tailnet-only, Tailscale cert for valid TLS.
# {$VAR} are read from the environment at runtime.

{$AIOS_HOSTNAME} {
	tls /certs/{$AIOS_HOSTNAME}.crt /certs/{$AIOS_HOSTNAME}.key

	@nextcloud path /files/* /remote.php/* /ocs/* /status.php /index.php*
	handle @nextcloud {
		reverse_proxy nextcloud:80
	}

	@intake path /intake/*
	handle @intake {
		reverse_proxy intake:8080
	}

	handle {
		reverse_proxy agent:3000
	}
}
