# Internal HTTP router — Tailscale serve handles TLS externally.
# Listens on :80 inside Docker; exposed to host as 127.0.0.1:8080.

:80 {
	@intake path /intake/*
	handle @intake {
		reverse_proxy intake:8080
	}

	# Nextcloud lives at /files (WebDAV stays at /remote.php/*)
	@nextcloud path /files /files/* /remote.php/* /status.php /ocs/* /apps/* /core/* /dist/*
	handle @nextcloud {
		reverse_proxy nextcloud:80
	}

	# Agent handles everything else including the chat UI at /
	handle {
		reverse_proxy agent:3000
	}
}
