# Internal HTTP router — Tailscale serve handles TLS externally.
# Listens on :80 inside Docker; exposed to host as 127.0.0.1:8080.

:80 {
	@intake path /intake/*
	handle @intake {
		reverse_proxy intake:8080
	}

	@agent path /health /chat /sessions /sessions/*
	handle @agent {
		reverse_proxy agent:3000
	}

	handle {
		reverse_proxy nextcloud:80
	}
}
