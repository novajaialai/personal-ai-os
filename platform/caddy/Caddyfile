# Reverse proxy — tailnet-only, Tailscale cert for valid TLS.

https://aios-jake-1.tail828365.ts.net {
	tls /certs/aios-jake-1.tail828365.ts.net.crt /certs/aios-jake-1.tail828365.ts.net.key

	@intake path /intake/*
	handle @intake {
		reverse_proxy intake:8080
	}

	# Nextcloud is the default handler (agent added in Phase 3)
	handle {
		reverse_proxy nextcloud:80
	}
}
