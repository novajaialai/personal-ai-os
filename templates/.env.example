# Copy to ../.env at provision. Secrets are generated/injected — NEVER committed.
# BYO keys for v1: each tenant supplies their own.

TAILSCALE_IP=
AIOS_HOSTNAME=aios-jake.tailnet.ts.net
VAULT_PATH=/srv/aios/vault

# --- Brain ---
ANTHROPIC_API_KEY=

# --- Capture / voice ---
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
RECALL_API_KEY=

# --- Datastores ---
POSTGRES_USER=aios
POSTGRES_PASSWORD=
POSTGRES_DB=aios

# --- Nango (self-hosted OAuth broker) ---
NANGO_ENCRYPTION_KEY=
NANGO_SERVER_URL=http://nango:3003
