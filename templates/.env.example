# Copy to ../.env at provision. Secrets are generated/injected — NEVER committed.
# BYO keys for v1: each tenant supplies their own.

TAILSCALE_IP=
AIOS_HOSTNAME=aios-jake.tailnet.ts.net
VAULT_PATH=/srv/aios/vault

# --- Brain ---
ANTHROPIC_API_KEY=

# --- Capture / voice ---
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
RECALL_API_KEY=

# --- Intake (webhook capture layer) ---
# Bearer token required on POST /intake/*. Generate with: openssl rand -hex 32
INTAKE_SHARED_SECRET=

# --- Datastores ---
POSTGRES_USER=aios
POSTGRES_PASSWORD=
POSTGRES_DB=aios

# --- Nango (self-hosted OAuth broker) ---
NANGO_ENCRYPTION_KEY=
NANGO_SERVER_URL=http://nango:3003

# --- Business OS layer: CRM / BI / workflow spine ---
# Each service is exposed on its own tailscale-served HTTPS port, not a Caddy subpath.
# See docs/roadmap-full-os.md.

# CRM (Twenty — github.com/twentyhq/twenty)
TWENTY_PG_PASSWORD=
TWENTY_ENCRYPTION_KEY=
TWENTY_SERVER_URL=https://REPLACE_WITH_TAILSCALE_HOSTNAME:8443

# BI / dashboards (Metabase)
METABASE_SITE_URL=https://REPLACE_WITH_TAILSCALE_HOSTNAME:8444

# Workflow automation (n8n)
N8N_HOSTNAME=REPLACE_WITH_TAILSCALE_HOSTNAME:8445
N8N_ENCRYPTION_KEY=

# --- Agent service access (the agent's own keys into the business stack) ---
# Add each with: scripts/add-secret.sh <VAR>  (never paste secrets into chat/git)
# Twenty: Settings -> APIs & Webhooks -> Create API key
TWENTY_API_KEY=
# Metabase: Admin settings -> Authentication -> API keys -> Create (group: Administrators)
METABASE_API_KEY=
# n8n: Settings -> n8n API -> Create API key
N8N_API_KEY=
# Nextcloud: Personal settings -> Security -> Devices & sessions -> new app password
NEXTCLOUD_USER=
NEXTCLOUD_APP_PASSWORD=
